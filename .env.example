# ──────────────────────────────────────────────
# Spectra — Environment Variables Setup Example
# ──────────────────────────────────────────────

# ── Base Currency ────────────────────────────
# The base currency used for all output and budgets.
# Use standard 3-letter ISO 4217 codes (e.g., EUR, USD, GBP, JPY, CAD)
# If a transaction is in a different currency, Spectra will use the
# free Frankfurter API to convert it to this currency using historical rates.
BASE_CURRENCY=EUR

# ── Google Sheets ────────────────────────────
# Path to your Google Cloud Service Account JSON file.
GOOGLE_SHEETS_CREDENTIALS_FILE=credentials.json
# Alternatively, provide the JSON content as a base64 string for CI/CD environments:
# GOOGLE_SHEETS_CREDENTIALS_B64=
# The ID of your Google Sheet (from its URL):
SPREADSHEET_ID=your_google_sheet_id_here

# ── AI Provider ──────────────────────────────
# Choose 'openai', 'gemini', or 'local' (fully offline, no API keys needed)
AI_PROVIDER=openai

# If using OpenAI:
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-5-nano

# If using Gemini (free tier available):
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-3-flash-preview

# ── Developer Config ─────────────────────────
LOG_LEVEL=INFO
